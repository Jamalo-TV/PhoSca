DATABASE_URL=postgresql+asyncpg://digitizer:digitizer_password@postgres:5432/digitizer
REDIS_URL=redis://redis:6379/0
STORAGE_PATH=/app/storage
HOST_STORAGE_PATH=/absolute/path/to/PhoSca/storage
MAX_UPLOAD_SIZE=52428800
MAX_REQUEST_SIZE=209715200
BLUR_THRESHOLD=100.0
YOLO_CONFIDENCE_THRESHOLD=0.7
YOLO_MODEL_PATH=/app/models/yolov8-seg-album.onnx
ENABLE_PHOTO_ORIENTATION_CORRECTION=true
PHOTO_ORIENTATION_MODEL_PATH=/app/models/photo-orientation.onnx
PADDLEOCR_MODEL_PATH=/app/models/paddleocr/
PADDLEOCR_LANGUAGE=en
ENABLE_LLM_FALLBACK=false
LLM_MODEL_PATH=/app/models/llava-phi3/
LOG_LEVEL=INFO
CELERY_TASK_ALWAYS_EAGER=false
ENABLE_CLASSICAL_SEGMENTATION_FALLBACK=true
POSTGRES_USER=digitizer
POSTGRES_PASSWORD=digitizer_password
POSTGRES_DB=digitizer
